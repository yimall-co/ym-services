{
    "$schema": "https://turborepo.dev/schema.json",
    "globalEnv": ["NODE_ENV", "APP_PORT", "PORT"],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", "build/**"]
        },
        "dev": {
            "persistent": true,
            "cache": true,
            "dependsOn": ["//#compose"]
        },
        "start": {
            "dependsOn": ["build"]
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "migration:generate": {
            "dependsOn": ["^migration:generate"]
        },
        "migration:migrate": {
            "dependsOn": ["^migration:migrate"]
        },
        "migration:push": {
            "dependsOn": ["^migration:push"]
        },
        "migration:pull": {
            "dependsOn": ["^migration:pull"]
        },
        "//#compose": {}
    }
}
