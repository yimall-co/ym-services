{
    "$schema": "https://turborepo.dev/schema.json",
    "globalEnv": [
        "NODE_ENV",
        "PORT",
        "APP_PORT",
        "APP_NAME",
        "APP_VERSION",
        "APP_DESCRIPTION",
        "LOCKER_API_URL",
        "LOCKER_ENVIRONMENT",
        "LOCKER_READ_ACCESS_KEY",
        "LOCKER_READ_SECRET_KEY",
        "LOCKER_WRITE_ACCESS_KEY",
        "LOCKER_WRITE_SECRET_KEY",
        "DB_URL"
    ],
    "globalDependencies": [".env", ".env.development", ".env.test", ".env.production"],
    "tasks": {
        "build": {
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "dependsOn": ["^build"],
            "outputs": ["dist/**", "build/**"]
        },
        "dev": {
            "persistent": true,
            "cache": true,
            "dependsOn": ["//#compose"]
        },
        "start": {
            "dependsOn": ["build", "migration:push"]
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "migration:generate": {
            "dependsOn": ["^migration:generate"]
        },
        "migration:migrate": {
            "dependsOn": ["^migration:migrate"]
        },
        "migration:push": {
            "dependsOn": ["migration:generate"]
        },
        "migration:pull": {
            "dependsOn": ["^migration:pull"]
        },
        "//#compose": {}
    }
}
